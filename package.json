{
  "name": "nextacular",
  "version": "1.4.2",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write . --ignore-path .prettierignore",
    "format:check": "prettier --check . --ignore-path .prettierignore",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d postgres mailpit adminer",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres && npx prisma migrate deploy && npx prisma db seed",
    "db:logs": "docker compose logs -f postgres",
    "db:studio": "prisma studio",
    "seed": "prisma db seed",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.7",
    "@heroicons/react": "^2.0.12",
    "@next-auth/prisma-adapter": "^1.0.4",
    "@prisma/client": "^4.8.0",
    "@stripe/stripe-js": "^1.38.1",
    "date-fns": "^2.29.3",
    "express-validator": "^6.14.2",
    "i18next": "^23.5.1",
    "micro": "^9.4.1",
    "next": "^13.5.1",
    "next-auth": "^4.24.5",
    "next-themes": "^0.2.1",
    "nodemailer": "^6.8.0",
    "react": "^18.2.0",
    "react-copy-to-clipboard": "^5.1.0",
    "react-dom": "^18.2.0",
    "react-ga": "^3.3.1",
    "react-hot-toast": "^2.4.0",
    "react-i18next": "^13.3.0",
    "react-topbar-progress-indicator": "^4.1.1",
    "slugify": "^1.6.5",
    "stripe": "^10.13.0",
    "swr": "^1.3.0",
    "validator": "^13.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/nodemailer": "~6.4.0",
    "@types/react": "~18.2.0",
    "@types/react-copy-to-clipboard": "^5.0.7",
    "@types/react-dom": "~18.2.0",
    "@types/validator": "^13.15.10",
    "autoprefixer": "^10.4.1",
    "eslint": "^8.14.0",
    "eslint-config-next": "^13.1.0",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.4.31",
    "prettier": "^3.8.3",
    "prisma": "^4.8.0",
    "tailwindcss": "^3.0.11",
    "tsx": "^4.22.3",
    "typescript": "~5.6.0"
  }
}
