{
  "name": "nextacular",
  "version": "1.4.2",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write . --ignore-path .prettierignore",
    "format:check": "prettier --check . --ignore-path .prettierignore",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d postgres mailpit adminer",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres && npx prisma migrate deploy && npx prisma db seed",
    "db:logs": "docker compose logs -f postgres",
    "db:studio": "prisma studio",
    "seed": "prisma db seed",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.19",
    "@heroicons/react": "^2.2.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.3",
    "@stripe/stripe-js": "^1.54.2",
    "date-fns": "^2.30.0",
    "i18next": "^23.16.8",
    "next": "^13.5.11",
    "next-auth": "^4.24.14",
    "next-themes": "^0.2.1",
    "nodemailer": "^7.0.7",
    "nprogress": "^0.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^13.5.0",
    "slugify": "^1.6.9",
    "stripe": "^10.17.0",
    "swr": "^1.3.0",
    "validator": "^13.15.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/nodemailer": "~7.0.0",
    "@types/nprogress": "^0.2.3",
    "@types/react": "~18.2.79",
    "@types/react-dom": "~18.2.25",
    "@types/validator": "^13.15.10",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^13.5.11",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.3",
    "typescript": "~5.6.0"
  }
}
