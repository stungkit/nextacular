###
# Required to boot — the app will not start without these.
###

# Public URL of the app. In local dev this is http://localhost:3000.
APP_URL=http://localhost:3000

# Secret used by NextAuth to sign session JWTs. Generate with:
#   openssl rand -base64 32
# Never reuse the value below in production.
NEXTAUTH_SECRET=replace-me-with-an-openssl-rand-base64-32-value

# PostgreSQL connection string. The default matches docker-compose.yml.
# If you use a hosted Postgres (Supabase, Neon, Railway), paste that URL here.
DATABASE_URL=postgresql://nextacular:nextacular@localhost:5432/nextacular

# Optional shadow database used by Prisma Migrate for safety against
# destructive schema changes. Required when DATABASE_URL points at a
# managed/cloud database that disallows CREATE/DROP DATABASE.
# SHADOW_DATABASE_URL=postgresql://nextacular:nextacular@localhost:5432/nextacular_shadow

###
# Email — required for magic-link authentication.
# The defaults below match the Mailpit service in docker-compose.yml.
# All outgoing email is captured at http://localhost:8025 in local dev.
###

EMAIL_FROM=Nextacular <hello@nextacular.test>
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
# Use any well-known nodemailer service (https://nodemailer.com/smtp/well-known/)
# or leave blank to use the SMTP host/port defaults.
EMAIL_SERVICE=

###
# Stripe billing — only required if the billing/upgrade UI is in use.
# Leave commented out to disable billing features.
###

# NEXT_PUBLIC_PUBLISHABLE_KEY=pk_test_...
# PAYMENTS_SECRET_KEY=sk_test_...
# PAYMENTS_SIGNING_SECRET=whsec_...

###
# Google Analytics 4 — optional. Only initialised in production builds.
###

# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

###
# Vercel — required only when adding custom domains to a workspace.
# Get the project + team IDs from https://vercel.com/<team>/<project>/settings
# and a bearer token from https://vercel.com/account/tokens
###

NEXT_PUBLIC_VERCEL_IP_ADDRESS=76.76.21.21
VERCEL_API_URL=https://api.vercel.com
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=
# VERCEL_AUTH_BEARER_TOKEN=

###
# Seed values — used by `npm run seed` to populate the demo workspace.
###

ADMIN_EMAIL=admin@nextacular.test
